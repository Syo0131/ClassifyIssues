AUTH_SECRET=replace_with_a_64_char_random_secret
AUTH_SESSION_VERSION=1
AUTH_URL=http://localhost:3000
GEMINI_API_KEY=replace_with_your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# PostgreSQL (recommended: use DATABASE_URL)
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/support_system

# PostgreSQL (alternative to DATABASE_URL)
PGHOST=localhost
PGPORT=5432
PGUSER=app_user
PGPASSWORD=app_password
PGDATABASE=support_system
PGSSL=false